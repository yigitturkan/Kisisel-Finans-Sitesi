@{
    ViewData["Title"] = "Sık Sorulan Sorular";
}

<!-- HEADER -->
<section class="py-5 bg-light text-center">
    <div class="container">
        <h1 class="fw-bold">Sık Sorulan Sorular</h1>
        <p class="text-muted fs-5">
            Merak ettiğiniz soruların cevaplarını burada bulabilirsiniz.
        </p>
    </div>
</section>


<!-- FAQ -->
<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">

                <div class="accordion shadow-sm" id="faqAccordion">

                    <!-- Soru 1 -->
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button"
                                    type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#faq1">
                                Uygulama ücretsiz mi?
                            </button>
                        </h2>
                        <div id="faq1"
                             class="accordion-collapse collapse show"
                             data-bs-parent="#faqAccordion">
                            <div class="accordion-body">
                                Evet, temel özellikler tamamen ücretsizdir.
                                Gelecekte ek premium özellikler sunulabilir.
                            </div>
                        </div>
                    </div>

                    <!-- Soru 2 -->
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed"
                                    type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#faq2">
                                Verilerim güvende mi?
                            </button>
                        </h2>
                        <div id="faq2"
                             class="accordion-collapse collapse"
                             data-bs-parent="#faqAccordion">
                            <div class="accordion-body">
                                Tüm kullanıcı verileri modern güvenlik standartları
                                ile korunur ve üçüncü kişilerle paylaşılmaz.
                            </div>
                        </div>
                    </div>

                    <!-- Soru 3 -->
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed"
                                    type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#faq3">
                                Telefonumdan kullanabilir miyim?
                            </button>
                        </h2>
                        <div id="faq3"
                             class="accordion-collapse collapse"
                             data-bs-parent="#faqAccordion">
                            <div class="accordion-body">
                                Evet. Platform tamamen responsive tasarıma sahiptir
                                ve mobil cihazlarda sorunsuz çalışır.
                            </div>
                        </div>
                    </div>

                    <!-- Soru 4 -->
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed"
                                    type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#faq4">
                                Hesabımı silebilir miyim?
                            </button>
                        </h2>
                        <div id="faq4"
                             class="accordion-collapse collapse"
                             data-bs-parent="#faqAccordion">
                            <div class="accordion-body">
                                Evet. Ayarlar bölümünden hesabınızı kalıcı olarak
                                silebilirsiniz.
                            </div>
                        </div>
                    </div>

                </div>

            </div>
        </div>
    </div>
</section>


<!-- CTA -->
<section class="bg-light py-5 text-center">
    <div class="container">
        <h3 class="fw-bold">Başka sorunuz mu var?</h3>
        <p class="text-muted">Bizimle iletişime geçmekten çekinmeyin.</p>

        <a href="@Url.Action("Contact","Home")" class="btn btn-primary btn-lg">
            İletişime Geç
        </a>
    </div>
</section>