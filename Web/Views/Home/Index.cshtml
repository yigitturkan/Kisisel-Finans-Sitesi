@{
    ViewBag.Title = "AnaSayfa";
}

@* İlk Tanıtım Kutusu *@
<section class="bg-light bg-gradient py-5 border-bottom">
    <div class="container">
        <div class="row align-items-center text-center">

            <div class="col-md-6">
                <span class="badge bg-success-subtle text-success mb-3 px-3 py-2">
                    💰 Akıllı Finans Yönetimi
                </span>

                <h1 class="display-4 fw-bold">
                    Paran Nereye Gidiyor Artık Bil.
                </h1>

                <p class="lead text-muted my-4">
                    Gelir ve giderlerini kolayca takip et,
                    bütçeni yönet ve finansal kontrolü eline al.
                </p>

                <div class="mt-3">
                    <a href="@Url.Action("Register", "Account")" class="btn btn-outline-primary btn-lg px-4 me-2 shadow-sm">
                        Ücretsiz Başla
                    </a>
                    <a href="@Url.Action("Login", "Account")" class="btn btn-outline-dark btn-lg px-4">
                        Giriş Yap
                    </a>
                </div>
            </div>

            <div class="col-md-6 text-center mt-4 mt-md-0">
                <img src="https://picsum.photos/800/450"
                     class="img-fluid rounded-4 shadow"
                     alt="Finans Takibi" />
            </div>

        </div>
    </div>
</section>

@* Site Tanıtım Kartları *@
<section class="py-5">
    <div class="container text-center">

        <h2 class="fw-bold mb-2">Bu Site ile Neler Yapabilirsin?</h2>
        <p class="text-muted mb-5">Finans yönetimini basitleştiren araçlar</p>

        <div class="row g-4">

            <div class="col-md-4">
                <div class="card h-100 shadow-sm border-0 rounded-4 p-3 feature-card">
                    <div class="card-body">
                        <div class="fs-1 mb-3">💸</div>
                        <h5 class="fw-bold">Harcama Takibi</h5>
                        <p class="text-muted">
                            Günlük gelir ve giderlerini hızlıca ekle ve düzenle.
                        </p>
                        <a href="https://asp.net" class="btn btn-outline-primary btn-sm mt-2">Daha Fazla &raquo;</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card h-100 shadow-sm border-0 rounded-4 p-3 feature-card">
                    <div class="card-body">
                        <div class="fs-1 mb-3">📊</div>
                        <h5 class="fw-bold">Raporlama</h5>
                        <p class="text-muted">
                            Harcamalarını grafiklerle detaylıca analiz et.
                        </p>
                        <a href="https://go.microsoft.com/fwlink/?LinkId=301865" class="btn btn-outline-primary btn-sm mt-2">Daha Fazla &raquo;</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card h-100 shadow-sm border-0 rounded-4 p-3 feature-card">
                    <div class="card-body">
                        <div class="fs-1 mb-3">🎯</div>
                        <h5 class="fw-bold">Bütçe Yönetimi</h5>
                        <p class="text-muted">
                            Aylık limitler belirle ve harcamalarını aşmadan yönet.
                        </p>
                        <a href="https://go.microsoft.com/fwlink/?LinkId=301866" class="btn btn-outline-primary btn-sm mt-2">Daha Fazla &raquo;</a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

@* Nasıl Çalışır *@
<section class="bg-light py-5">
    <div class="container text-center">

        <h2 class="fw-bold mb-5">Nasıl Çalışır?</h2>

        <div class="row g-4">

            <div class="col-md-4">
                <div class="p-4">
                    <div class="bg-success text-white rounded-circle d-inline-flex
                                align-items-center justify-content-center mb-3"
                         style="width:60px;height:60px;font-size:22px;">
                        1
                    </div>
                    <h5 class="fw-bold">Hesap Oluştur</h5>
                    <p class="text-muted">
                        Ücretsiz kayıt ol ve hemen kullanmaya başla.
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="p-4">
                    <div class="bg-success text-white rounded-circle d-inline-flex
                                align-items-center justify-content-center mb-3"
                         style="width:60px;height:60px;font-size:22px;">
                        2
                    </div>
                    <h5 class="fw-bold">İşlemlerini Ekle</h5>
                    <p class="text-muted">
                        Gelir ve giderlerini saniyeler içinde kaydet.
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="p-4">
                    <div class="bg-success text-white rounded-circle d-inline-flex
                                align-items-center justify-content-center mb-3"
                         style="width:60px;height:60px;font-size:22px;">
                        3
                    </div>
                    <h5 class="fw-bold">Analiz Et</h5>
                    <p class="text-muted">
                        Grafiklerle finansal durumunu net şekilde gör.
                    </p>
                </div>
            </div>

        </div>
    </div>
</section>