@model Web.Models.ResetPasswordViewModel1
@{
    ViewBag.Title = "Şifre Sıfırla";
}

<section class="d-flex align-items-center justify-content-center min-vh-100">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5">
                <div class="card shadow-sm rounded-4 p-4">
                    <h3 class="text-center mb-4">Yeni Şifre Belirle</h3>

                    @using (Html.BeginForm("ResetPassword", "Account", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        @Html.HiddenFor(m => m.Code)

                        <div class="mb-3">
                            @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "Eposta adresi" })
                        </div>

                        <div class="mb-3">
                            @Html.PasswordFor(m => m.Password, new { @class = "form-control", placeholder = "Yeni şifre" })
                        </div>

                        <div class="mb-3">
                            @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "form-control", placeholder = "Şifre tekrar" })
                        </div>

                        <button type="submit" class="btn btn-primary w-100">Şifreyi Güncelle</button>
                    }
                </div>
            </div>
        </div>
    </div>
</section>